{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "crons": [
        {
            "path": "/api/cron/daily-digest",
            "schedule": "0 13 * * *"
        },
        {
            "path": "/api/cron/weekly-digest",
            "schedule": "0 13 * * 1"
        },
        {
            "path": "/api/cron/monthly-digest",
            "schedule": "0 13 1 * *"
        }
    ]
}
